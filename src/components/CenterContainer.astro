---

---

<main class="cc">
	<div>
		<slot />
	</div>
</main>

<style>
	main {
		margin: 0 auto;
		width: 100%;
		max-width: 1920px;
		padding: 0;
		position: relative;
		box-sizing: border-box;
		box-shadow:
			-20px 0 30px -20px rgba(0, 0, 0, 0.25),
			20px 0 30px -20px rgba(0, 0, 0, 0.25);
	}

	div {
		color: var(--text);
		background-image: linear-gradient(
			135deg,
			#fcfcfc 25%,
			#f5f5f5 25%,
			#f5f5f5 50%,
			#fcfcfc 50%,
			#fcfcfc 75%,
			#f5f5f5 75%,
			#f5f5f5 100%
		);
		background-size: 28.28px 28.28px;
	}

	@media (prefers-color-scheme: dark) {
		div {
			background-image: linear-gradient(
				135deg,
				#35153d 25%,
				#2d1133 25%,
				#2d1133 50%,
				#35153d 50%,
				#35153d 75%,
				#2d1133 75%,
				#2d1133 100%
			);
		}
	}
</style>
