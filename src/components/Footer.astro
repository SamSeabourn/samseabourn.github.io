---
import Button from './Button.astro';
import linkedinLogo from '../assets/linked-in-logo.svg';
import githubLogo from '../assets/github.svg';
import emailLogo from '../assets/email-logo.svg';

interface Props {
	githubUrl?: string;
	linkedinUrl?: string;
	email?: string;
}

const {
	githubUrl = 'https://github.com',
	linkedinUrl = 'https://linkedin.com',
	email = 'mailto:contact@example.com',
} = Astro.props;
---

<footer class="footer-section">
	<div class="footer-container">
		<div class="contact-grid">
			<h2 class="heading footer-title">Let's Connect</h2>
			<div class="contact-items-group">
				<Button href={linkedinUrl} text="LinkedIn" icon={linkedinLogo.src} type="primary" />
				<Button href={githubUrl} text="GitHub" icon={githubLogo.src} type="primary" />
				<Button href={email} text="Email" icon={emailLogo.src} type="primary" id="email-button" />
			</div>
		</div>
	</div>
</footer>

<script>
	// Anti-scraper email obfuscation
	const emailButton = document.getElementById('email-button');
	if (emailButton) {
		const user = 'sam.seabourn';
		const domain = 'gmail.com';
		const mailto = 'mailto:' + user + '@' + domain;
		emailButton.setAttribute('href', mailto);
	}
</script>

<style>
	.footer-section {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.footer-title {
		text-align: left;
		color: #000;
		background: none;
		padding: 0;
		margin: 0;
		font-size: clamp(1.5rem, 2vw, 2rem);
		position: relative;
		z-index: 2;
		white-space: nowrap;
	}

	.footer-container {
		width: 100%;
		background-color: #f0e02d;
		padding: clamp(1rem, 2vw, 2rem) 0;
		margin-top: -0.5rem;
	}

	.footer-container > .contact-grid {
		width: clamp(80%, 85vw, 90%);
		max-width: 1400px;
		margin: 0 auto;
	}

	.contact-grid {
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 0;
		justify-content: space-between;
	}

	.contact-items-group {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1rem;
	}

	/* Responsive adjustments */
	@media (max-width: 768px) {
		.contact-grid {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
		}

		.contact-items-group {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}
	}
</style>
