---
import SVG1 from '../assets/layer-1.svg';
import SVG2 from '../assets/layer-2.svg';
import SVG3 from '../assets/layer-3.svg';
import downloadLogo from '../assets/download-logo.svg';
import Button from './Button.astro';
import { asset } from '../utils/base-url';
---

<div class="svg-stack">
	<div class="resume-button-wrapper">
		<div class="resume-button">
			<Button
				href={asset('resume.pdf')}
				text="Download Resume"
				icon={downloadLogo.src}
				type="primary"
				download
			/>
		</div>
	</div>
	<svg id="svg1" data-svg-url={SVG1.src} class="stacked-svg" style="opacity: 0"></svg>
	<svg id="svg2" data-svg-url={SVG2.src} class="stacked-svg" style="opacity: 0"></svg>
	<svg id="svg3" data-svg-url={SVG3.src} class="stacked-svg" style="opacity: 0"></svg>
	<div class="stacked">
		<div class="sam-pic-wrapper">
			<picture>
				<source
					media="(min-width: 1200px)"
					srcset={asset('hero-lg.png')}
					width="700"
					height="700"
				/>
				<source media="(min-width: 416px)" srcset={asset('hero-md.png')} width="450" height="450" />
				<img
					src={asset('hero-sm.png')}
					alt="Engineer sitting cross legged"
					width="300"
					height="300"
					loading="eager"
					fetchpriority="high"
					style="opacity: 1; image-rendering: pixelated;"
					decoding="async"
					class="sam-pic"
				/>
			</picture>
		</div>
	</div>
	<div class="stacked">
		<span class="hero-heading hero-text">I BUILD THINGS</span>
	</div>
	<div class="hero-sub-text-wrapper">
		<p class="hero-sub-text">Sam - Frontend Systems Engineer - Sydney</p>
	</div>
</div>

<style>
	.svg-stack {
		position: relative;
		width: 100%;
		height: 80vh;
		margin-bottom: 4vh;
		padding-top: 4vh;
		transform: translateZ(0);
	}

	.resume-button-wrapper {
		position: relative;
		z-index: 200;
		height: 100%;
		width: 100%;
	}

	.resume-button {
		height: 4rem;
		position: absolute;
		right: 1rem;
	}

	@media (max-width: 768px) {
		.resume-button {
			bottom: 0;
		}
	}

	.stacked-svg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		transform: translateZ(0);
		pointer-events: none;
	}

	.stacked {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		display: flex;
		justify-content: center;
		align-items: center;
		transform: scale(0.75) translateZ(0);
		pointer-events: none;
	}

	@media (max-width: 768px) {
		.stacked {
			transform: scale(0.95) translateZ(0);
		}
	}

	.stacked-svg.visible {
		opacity: 1;
	}

	.sam-pic-wrapper {
		width: clamp(300px, 50vw, 600px);
		height: clamp(300px, 50vw, 600px);
		background-color: #ebdf45;
		clip-path: polygon(
			39% 8%,
			37% 34%,
			22% 27%,
			3% 59%,
			8% 79%,
			4% 96%,
			44% 96%,
			69% 100%,
			94% 94%,
			92% 60%,
			81% 45%,
			81% 21%,
			73% 1%,
			46% 0%
		);
	}

	.sam-pic {
		width: 100%;
		height: 100%;
	}

	.hero-text {
		position: absolute;
		z-index: 10;
		font-size: clamp(4rem, 8vw, 10rem);
		transform: rotate(4deg) translateY(clamp(4rem, 10vw, 10rem)) translateZ(0);
		color: var(--text);
		text-align: center;
		background-color: var(--bg);
		opacity: 0.9;
	}

	.hero-sub-text-wrapper {
		width: 100%;
		display: flex;
		position: absolute;
		top: 0;
		height: 100%;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	.hero-sub-text {
		position: absolute;
		z-index: 10;
		padding: 0.25rem;
		transform: rotate(-2deg) translateY(calc((clamp(300px, 40vw, 500px) * 0.75 / 2) + 50px));
		font-size: clamp(1rem, 2vw, 2.5rem);
		color: #000;
		text-align: center;
		background-color: var(--bg);
		opacity: 0.9;
	}

	@media (prefers-color-scheme: dark) {
		.hero-text,
		.hero-sub-text {
			color: #fff;
		}
	}
</style>

<script is:inline>
	// Use functions from window (inlined in Layout.astro head)
	window.addEventListener('load', () => {
		requestIdleCallback(async () => {
			window.createFirstInteractionListener(async () => {
				const svg1 = document.getElementById('svg1');
				const svg2 = document.getElementById('svg2');
				const svg3 = document.getElementById('svg3');

				const svg1Url = svg1.getAttribute('data-svg-url');
				const svg2Url = svg2.getAttribute('data-svg-url');
				const svg3Url = svg3.getAttribute('data-svg-url');

				if (svg1Url) await window.mountSVG(svg1, svg1Url);
				if (svg2Url) await window.mountSVG(svg2, svg2Url);
				if (svg3Url) await window.mountSVG(svg3, svg3Url);

				await window.animateSvgPath(svg1, {
					duration: 0.5,
					steps: 15,
				});
				await window.animateSvgPath(svg2, {
					duration: 1,
					steps: 15,
				});
				await window.animateSvgPath(svg3, {
					duration: 1.5,
					steps: 15,
				});
			});
		});
	});
</script>
