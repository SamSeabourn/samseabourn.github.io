---
interface Props {
	svgSrc: string;
	title: string;
	id: string;
}

const { svgSrc, title, id } = Astro.props;
---

<svg
	data-hand-draw
	data-svg-url={svgSrc || 'fuckk'}
	id={id}
	class="logo-svg"
	width="150"
	height="150"
	style="opacity: 0"></svg>
<h3 class="subheading">{title}</h3>

<style>
	.logo-svg {
		max-width: 55%;
		padding: 0.5rem;
		height: auto;
		width: 100%;
	}

	h3 {
		text-align: center;
	}
</style>
