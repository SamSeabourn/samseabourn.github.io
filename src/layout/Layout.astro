---
import BuildStats from '../components/BuildStats.astro';
import '../styles/global.css';
import { asset } from '../utils/base-url';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Sam Seabourn | Senior Frontend Engineer</title>
		<meta
			name="description"
			content="Senior Frontend Engineer specialising in high-performance TypeScript systems for Smart TVs, browser extensions, and large-scale platforms."
		/>
		<link
			rel="preload"
			href={asset('DepartureMono-Regular-full.woff2')}
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<script>
			import { animateSvgPath } from '../helpers/animate-svg-path';
			import { mountSVG } from '../helpers/mount-svg';
			import { createFirstInteractionListener } from '../helpers/create-first-interaction-listener';
			window.createFirstInteractionListener = createFirstInteractionListener;
			window.mountSVG = mountSVG;
			window.animateSvgPath = animateSvgPath;
		</script>
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#200827" media="(prefers-color-scheme: dark)" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
		<link rel="apple-touch-icon" href={asset('apple-touch-icon.png')} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Sam Seabourn | Senior Frontend Engineer" />
		<meta
			property="og:description"
			content="Senior Frontend Engineer with 6+ years of experience building performance critical TypeScript systems for Smart TVs, browser extensions and large-scale streaming platforms. Google contributor."
		/>
		<meta property="og:url" content={`https://samseabourn.github.io${asset('')}`} />
		<meta property="og:image" content={`https://samseabourn.github.io${asset('hero-md.png')}`} />
	</head>
	<body>
		<slot />
		{Astro.url.pathname === '/' && <BuildStats />}
	</body>
</html>
