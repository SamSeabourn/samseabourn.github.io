---
import CenterContainer from '../components/CenterContainer.astro';
import Button from '../components/Button.astro';
import ContentCard from '../components/ContentCard.astro';
import BigText from '../components/BigText.astro';
import Opstar from '../assets/opstar.svg';
import Paragraph from '../components/Paragraph.astro';
import Hero from '../components/Hero.astro';
import Layout from '../layout/Layout.astro';
import Bento from '../components/Bento.astro';
import TrexLogo from '../assets/dino-frame-1.svg';
import reactLogo from '../assets/react-logo.svg';
import tsLogo from '../assets/ts-logo.svg';
import nodeLogo from '../assets/node-logo.svg';
import toolingLogo from '../assets/tooling-logo.svg';
import arcLogo from '../assets/arc-logo.svg';
import dxLogo from '../assets/dx-logo.svg';
import frameworkLogo from '../assets/framework-logo.svg';
import webpackLogo from '../assets/webpack-logo.svg';
import StanLogo from '../assets/stan.svg';
import PlaywrightEmbeddedLogo from '../assets/pw-embedded.svg';
import SaltLMSLogo from '../assets/salt-lms.svg';
import chromeextLogo from '../assets/chrome-ext-logo.svg';
import tvLogo from '../assets/tv-logo.svg';
import perfLogo from '../assets/perf-logo.svg';
import Spacer from '../components/Spacer.astro';
import pixiLogo from '../assets/pixi-logo.svg';
import compatLogo from '../assets/compat-logo.svg';
import greenFieldLogo from '../assets/green-field-logo.svg';
import spaghettiLogo from '../assets/spaghetti-logo.svg';
import spineLogo from '../assets/spine-logo.svg';
import viteLogo from '../assets/vite-logo.svg';
import zustandLogo from '../assets/zustand-logo.svg';
import pwLogo from '../assets/pw-logo.svg';
import ButtonWrapper from '../components/ButtonWrapper.astro';
import shakaLogo from '../assets/shaka-logo.svg';
import Footer from '../components/Footer.astro';
import { asset } from '../utils/base-url';
---

<Layout>
	<CenterContainer>
		<Hero />
		<ContentCard title="About Me">
			<Bento associatedLogos={[]} layoutVariant="alt">
				<slot slot="top-left">
					<img
						src={asset('line-drawing-md.png')}
						srcset={`${asset('line-drawing-sm.png')} 150w, ${asset('line-drawing-md.png')} 200w, ${asset('line-drawing-lg.png')} 300w, ${asset('line-drawing-xl.png')} 400w`}
						sizes="(min-width: 768px) 200px, 150px"
						alt="Sam Line drawing"
						width="200"
						height="338"
						loading="lazy"
						decoding="async"
					/>
				</slot>
				<slot slot="top-right">
					<Paragraph heading="Hi I’m Sam, A Frontend Systems Engineer.">
						I’m a Systems Engineer with over six years of experience designing and building
						performance critical systems for constrained environments.
						<br />
						While my primary stack is React, TypeScript and Redux, I’m a web purist at heart and regularly
						go beyond frameworks when the problem demands it.
						<br />
						Outside of work, I’m usually raising my two boys, out on my bike, or at my desk making something
						with software, hardware or keeping my 3D printer busy.
					</Paragraph>
				</slot>
			</Bento>
		</ContentCard>
		<Spacer triple />
		<BigText title={'My Work'} />
		<ContentCard>
			<Bento
				associatedLogos={[
					{ svgSrc: reactLogo.src, title: 'React' },
					{ svgSrc: tsLogo.src, title: 'TypeScript' },
					{ svgSrc: nodeLogo.src, title: 'Node.js' },
					{ svgSrc: shakaLogo.src, title: 'Shaka Player' },
					{ svgSrc: toolingLogo.src, title: 'Internal Tooling' },
					{ svgSrc: arcLogo.src, title: 'Frontend System Design' },
					{ svgSrc: dxLogo.src, title: 'Developer Experience' },
					{ svgSrc: frameworkLogo.src, title: 'Frameworks Design' },
					{ svgSrc: webpackLogo.src, title: 'Webpack' },
					{ svgSrc: tvLogo.src, title: 'OTT, Smart TV, Console' },
					{ svgSrc: compatLogo.src, title: 'Browser Compatibility' },
					{ svgSrc: perfLogo.src, title: 'Web Performance Optimisation' },
					{ svgSrc: spaghettiLogo.src, title: 'Legacy rewrite' },
				]}
				layoutVariant="alt"
			>
				<slot slot="top-left">
					<StanLogo width={400} height={400} class="invert-dark" />
				</slot>
				<slot slot="top-right">
					<Paragraph heading="TV Platforms Engineer, Stan">
						I architect and build the engine behind Australia's largest home grown streaming
						service. Delivering 2024 Olympics, live sport and video on demand to 1.6M+ users across
						175+ platforms as part of a 6 person core team. <br /> I specialize in high stakes architecture
						and performance in resource constrained environments.</Paragraph
					>
					<Spacer />
					<ButtonWrapper position="right">
						<Button href={asset('stan')} text="Behind the stream" />
					</ButtonWrapper>
				</slot>
			</Bento>
		</ContentCard>
		<Spacer double />
		<ContentCard skunkworks>
			<Bento
				associatedLogos={[
					{ svgSrc: reactLogo.src, title: 'React' },
					{ svgSrc: tsLogo.src, title: 'TypeScript' },
					{ svgSrc: pixiLogo.src, title: 'PixiJS' },
					{ svgSrc: zustandLogo.src, title: 'Zustand' },
					{ svgSrc: chromeextLogo.src, title: 'Extension Development' },
					{ svgSrc: spineLogo.src, title: 'Spine3D' },
					{ svgSrc: viteLogo.src, title: 'Vite' },
				]}
				layoutVariant="alt"
			>
				<slot slot="top-left">
					<TrexLogo width={400} height={400} class="invert-dark" />
				</slot>
				<slot slot="top-right">
					<Paragraph heading="Browsersaurus, Personal project">
						A Chrome extension game where every website you visit spawns a unique collectible
						dinosaur. Built solo to explore the challenge of running a fully featured creature
						collection game within browser extension constraints. No native modules, limited storage
						and deterministic skin generation.
					</Paragraph>
					<Spacer />
					<ButtonWrapper position="right">
						<Button href={asset('browsersaurus')} text="Life, uh... finds a way" />
					</ButtonWrapper>
				</slot>
			</Bento>
		</ContentCard>
		<Spacer double />
		<ContentCard skunkworks>
			<Bento
				associatedLogos={[
					{ svgSrc: pwLogo.src, title: 'Playwright' },
					{ svgSrc: toolingLogo.src, title: 'Custom Tooling' },
					{ svgSrc: tsLogo.src, title: 'TypeScript' },
					{ svgSrc: tvLogo.src, title: 'Smart TV Testing' },
					{ svgSrc: dxLogo.src, title: 'Developer Experience' },
				]}
				layoutVariant="alt"
			>
				<slot slot="top-left">
					<PlaywrightEmbeddedLogo width={400} height={400} class="invert-dark" />
				</slot>
				<slot slot="top-right">
					<Paragraph heading="Playwright-Embedded, Personal project">
						An automated testing framework solving a previously unsolved problem: running E2E tests
						on real hardware that uses embedded browsers. This project enables dynamic multi device
						test orchestration without CDP, additional hardware, manual device configs or awkward
						native platform test integration.
					</Paragraph>
					<Spacer />
					<ButtonWrapper position="right">
						<Button href={asset('playwright-embedded')} text="This shouldn't exist" />
					</ButtonWrapper>
				</slot>
			</Bento>
		</ContentCard>
		<Spacer double />
		<ContentCard>
			<Bento
				associatedLogos={[
					{ svgSrc: reactLogo.src, title: 'React' },
					{ svgSrc: tsLogo.src, title: 'TypeScript' },
					{ svgSrc: frameworkLogo.src, title: 'Hooks & Context' },
					{ svgSrc: greenFieldLogo.src, title: 'Greenfield' },
					{ svgSrc: spaghettiLogo.src, title: 'Legacy rewrite' },
				]}
				layoutVariant="alt"
			>
				<slot slot="top-left">
					<SaltLMSLogo width={400} height={400} class="invert-dark" />
				</slot>
				<slot slot="top-right">
					<Paragraph heading="Frontend Engineer, Salt LMS">
						The entire frontend of an award winning LMS, built solo from scratch. Working in React,
						TypeScript and CSS modules, I covered authentication via OAuth 2.0, a white label design
						system that let clients fully brand the product, dynamic certificate generation, multi
						language support and custom results dashboards. I also took a 22 year old legacy
						JavaScript SCORM player and rebuilt it as a clean React integration without breaking a
						thing. On top of all that, I introduced tooling and UX processes to a design team that
						had never worked in a structured design workflow before, effectively building the design
						function alongside the product.
					</Paragraph>
				</slot>
			</Bento>
		</ContentCard>
		<Spacer triple />
		<Footer
			githubUrl="https://github.com/samseabourn"
			linkedinUrl="https://linkedin.com/in/samseabourn"
			email="#"
		/>
	</CenterContainer>
	<script>
		import { getRuntimeStats } from '../helpers/runtime-stats';
		import { initIconObservers } from '../helpers/init-icon-observers';

		document.addEventListener('DOMContentLoaded', () => {
			if ('requestIdleCallback' in window) {
				requestIdleCallback(() => initIconObservers());
			} else {
				setTimeout(initIconObservers, 200);
			}
		});

		getRuntimeStats();
	</script>
</Layout>
